# ---------- OpenAI ----------
# API key personal de https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---------- Google Cloud / BigQuery ----------
# ID del proyecto de GCP que paga las queries de BigQuery
# (usado por bigquery.Client(project=...))
GOOGLE_CLOUD_PROJECT=tu-proyecto-gcp-id

# Región/location del proyecto (ej: us-central1, southamerica-east1)
GOOGLE_CLOUD_LOCATION=us-central1

# --- Local: ruta al archivo JSON ---
GOOGLE_APPLICATION_CREDENTIALS=credentials/tu-service-account.json

# --- Producción (EasyPanel): JSON en Base64 (recomendado, una sola línea) ---
# GOOGLE_CREDENTIALS_B64=pega_aqui_el_resultado_de_base64_sin_saltos_de_linea
# Alternativa: GOOGLE_CREDENTIALS_JSON='{"type":"service_account",...}'
# No uses GOOGLE_APPLICATION_CREDENTIALS en EasyPanel.


# ---------- Supabase / Postgres (histórico de conversaciones) ----------
# Credenciales de tu DB de Supabase (Project Settings → Database)
DB_USER=postgres
DB_PASSWORD=tu-password-aqui
DB_HOST=db.xxxxxxxxxxxxxxxx.supabase.co

# 5432 = conexión directa. 6543 = pooler de Supavisor (transaction mode).
DB_PORT=5432

# Nombre de la base de datos (por defecto en Supabase: postgres)
DB_NAME=postgres

# Schema dentro del cual el checkpointer de LangGraph creará sus 4 tablas
# (checkpoints, checkpoint_blobs, checkpoint_writes, checkpoint_migrations).
# Si el schema no existe, el código lo crea automáticamente.
DB_SCHEMA=agent_text_to_sql
